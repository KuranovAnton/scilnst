<Window x:Class="scilnst.EquipmentEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:scilnst"
        Title="{Binding WindowTitle}" 
        Height="750" 
        Width="650"
        WindowStartupLocation="CenterScreen"
        Closed="Window_Closed"
        Background="#F5F7FA"
        FontFamily="Times New Roman"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ModernGroupBox" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#E1E5EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#E1E5EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="{Binding FieldBackground}"/>
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                    <Setter Property="Foreground" Value="#6C757D"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#E1E5EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#E1E5EA"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  Background="#F5F7FA">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="White" 
                    CornerRadius="8" 
                    Padding="15" 
                    Margin="0,0,0,20"
                    BorderBrush="#E1E5EA"
                    BorderThickness="1">
                <TextBlock Text="{Binding WindowTitle}" 
                          FontSize="22" 
                          FontWeight="Bold" 
                          Foreground="#2C3E50"
                          HorizontalAlignment="Center"/>
            </Border>

            <GroupBox Grid.Row="1" 
                     Header="Фотография" 
                     Style="{StaticResource ModernGroupBox}"
                     BorderThickness="1"
>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Контейнер для фото с тенью -->
                    <Border Grid.Row="0" 
                            Background="#F8F9FA" 
                            CornerRadius="4" 
                            Margin="10"
                            BorderBrush="#E1E5EA"
                            BorderThickness="1">
                        <Image x:Name="imgEquipment" 
                              Source="{Binding PhotoImage}" 
                              Stretch="Uniform" 
                              Width="350" 
                              Height="220" 
                              Margin="5"/>
                    </Border>

                    <StackPanel Grid.Row="1" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Center" 
                                Margin="10"
                                Visibility="{Binding CanEdit, Converter={StaticResource BoolToVis}}">
                        <Button Content="📷 Выбрать фото" 
                                Click="SelectPhotoButton_Click" 
                                Margin="5"
                                Padding="15,8"
                                Background="#2196F3"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontSize="13">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Content="🗑 Удалить фото" 
                                Click="DeletePhotoButton_Click" 
                                Margin="5"
                                Padding="15,8"
                                Background="#F44336"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontSize="13"
                                Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVis}}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="2" 
                     Header="Наименование" 
                     Style="{StaticResource ModernGroupBox}">
                <TextBox x:Name="txtName" 
                        Text="{Binding EquipmentName}" 
                        IsReadOnly="{Binding IsReadOnly}"
                        Style="{StaticResource ModernTextBox}"/>
            </GroupBox>

            <!-- Инвентарный номер -->
            <GroupBox Grid.Row="3" 
                     Header="Инвентарный номер" 
                     Style="{StaticResource ModernGroupBox}">
                <TextBox x:Name="txtInventoryNumber" 
                        Text="{Binding InventoryNumber}" 
                        IsReadOnly="True"
                        Style="{StaticResource ModernTextBox}"
                        Background="#F8F9FA"/>
            </GroupBox>

            <GroupBox Grid.Row="4" 
                     Header="Описание" 
                     Style="{StaticResource ModernGroupBox}">
                <TextBox x:Name="txtDescription" 
                        Text="{Binding Description}" 
                        IsReadOnly="{Binding IsReadOnly}"
                        Height="100"
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        Style="{StaticResource ModernTextBox}"
                        VerticalScrollBarVisibility="Auto"/>
            </GroupBox>

            <GroupBox Grid.Row="5" 
                     Header="Подразделение" 
                     Style="{StaticResource ModernGroupBox}">
                <ComboBox x:Name="cmbDepartment" 
                         ItemsSource="{Binding Departments}"
                         DisplayMemberPath="FullName"
                         SelectedValuePath="DepartmentId"
                         SelectedValue="{Binding DepartmentId}"
                         IsEnabled="{Binding CanSelectDepartment}"
                         Style="{StaticResource ModernComboBox}"/>
            </GroupBox>

            <!-- Кабинет -->
            <GroupBox Grid.Row="6" 
                     Header="Кабинет" 
                     Style="{StaticResource ModernGroupBox}">
                <ComboBox x:Name="cmbRoom" 
                         ItemsSource="{Binding Rooms}"
                         DisplayMemberPath="RoomNumber"
                         SelectedValuePath="RoomId"
                         SelectedValue="{Binding RoomId}"
                         IsEnabled="{Binding CanEdit}"
                         Style="{StaticResource ModernComboBox}"/>
            </GroupBox>

            <Grid Grid.Row="7" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <GroupBox Grid.Column="0" 
                         Header="Вес (кг)" 
                         Style="{StaticResource ModernGroupBox}">
                    <TextBox x:Name="txtWeight" 
                            Text="{Binding Weight}" 
                            IsReadOnly="{Binding IsReadOnly}"
                            Style="{StaticResource ModernTextBox}"/>
                </GroupBox>

                <GroupBox Grid.Column="2" 
                         Header="Срок службы (лет)" 
                         Style="{StaticResource ModernGroupBox}">
                    <TextBox x:Name="txtServiceLife" 
                            Text="{Binding ServiceLifeYears}" 
                            IsReadOnly="{Binding IsReadOnly}"
                            Style="{StaticResource ModernTextBox}"/>
                </GroupBox>
            </Grid>

            <GroupBox Grid.Row="8" 
                     Header="Дата постановки на баланс" 
                     Style="{StaticResource ModernGroupBox}">
                <DatePicker x:Name="dpRegistrationDate" 
                           SelectedDate="{Binding RegistrationDate}"
                           IsEnabled="False"
                           Style="{StaticResource ModernDatePicker}"
                           Background="#F8F9FA"/>
            </GroupBox>

            <Border Grid.Row="9" 
                    Background="White" 
                    CornerRadius="8" 
                    Padding="20" 
                    Margin="0,20,0,0"
                    BorderBrush="#E1E5EA"
                    BorderThickness="1">
                <StackPanel Orientation="Horizontal" 
                           HorizontalAlignment="Center">

                    <Button Content="💾 Сохранить" 
                            Click="SaveButton_Click" 
                            Style="{StaticResource ModernButton}"
                            Background="#4CAF50"
                            Foreground="White"
                            Visibility="{Binding CanEdit, Converter={StaticResource BoolToVis}}"/>

                    <Button Content="🗑 Удалить"
                            Click="DeleteButton_Click" 
                            Style="{StaticResource ModernButton}"
                            Background="#F44336"
                            Foreground="White"
                            Visibility="{Binding CanDelete, Converter={StaticResource BoolToVis}}"/>

                    <Button Content="✖ Закрыть"
                            Click="CloseButton_Click" 
                            Style="{StaticResource ModernButton}"
                            Background="#9E9E9E"
                            Foreground="White"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>