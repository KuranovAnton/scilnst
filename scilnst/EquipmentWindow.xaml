<Window x:Class="scilnst.EquipmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:scilnst"
        Title="Окно просмотра оборудования" 
        Height="650" 
        Width="900"
        WindowStartupLocation="CenterScreen"
        Closed="Window_Closed"
        FontFamily="Times New Roman">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" 
                    Orientation="Horizontal" 
                    Margin="0,0,0,10"
                    HorizontalAlignment="Left">
            <Button Content="← На главную"
                    Click="ExitButton"
                    Padding="10,5"
                    Margin="0,0,10,0"/>

            <Button Content="➕ Добавить"
                    Click="AddEquipmentButton"
                    Padding="10,5"
                    Background="#4CAF50"
                    Foreground="White"
                    Visibility="{Binding CanAddEdit, Converter={StaticResource BoolToVis}}"/>

            <TextBlock x:Name="txtUserInfo"
                       VerticalAlignment="Center"
                       Margin="20,0,0,0"
                       FontWeight="SemiBold"/>
        </StackPanel>

        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    Margin="0,0,0,15"
                    Visibility="{Binding CanUseFilters, Converter={StaticResource BoolToVis}}">

            <TextBox x:Name="txtSearch" 
                     TextChanged="txtSearch_TextChanged"
                     Width="250"
                     Height="30"
                     Padding="5"
                     Margin="0,0,10,0"
                     ToolTip="Поиск"/>

            <ComboBox x:Name="cmbDepartmentFilter" 
                      SelectionChanged="cmbDepartmentFilter_SelectionChanged"
                      Width="200"
                      Height="30"
                      Margin="0,0,10,0"
                      DisplayMemberPath="DisplayName"/>

            <ComboBox x:Name="cmbSortOrder" 
                      SelectionChanged="cmbSortOrder_SelectionChanged"
                      Width="150"
                      Height="30">
                <ComboBoxItem Tag="None">Без сортировки</ComboBoxItem>
                <ComboBoxItem Tag="Ascending">Вес ↑</ComboBoxItem>
                <ComboBoxItem Tag="Descending">Вес ↓</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <ScrollViewer Grid.Row="2" 
                      VerticalScrollBarVisibility="Auto">

            <ListView x:Name="lvEquipment"
                      MouseDoubleClick="lvEquipment_MouseDoubleClick">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#CCCCCC" 
                                BorderThickness="1" 
                                CornerRadius="5" 
                                Padding="10" 
                                Margin="0,0,0,10"
                                Background="White">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" 
                                        BorderBrush="#DDDDDD" 
                                        BorderThickness="1" 
                                        CornerRadius="3"
                                        Width="100" 
                                        Height="100">
                                    <Image Source="{Binding PhotoImage, FallbackValue=/Images/stub.jpg, TargetNullValue=/Images/stub.jpg}"
                                           Stretch="Uniform"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="5,0">
                                    <TextBlock Text="{Binding Name}"  
                                               FontWeight="Bold" 
                                               FontSize="14"
                                               Margin="0,0,0,5"/>

                                    <TextBlock Text="{Binding Description}" 
                                               Margin="0,0,0,5"
                                               TextWrapping="Wrap"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="{Binding InventoryNumber}" 
                                                   Foreground="Gray"
                                                   Margin="0,0,15,0"/>
                                        <TextBlock Text="{Binding Weight, StringFormat=Вес: {0} кг}" 
                                                   Foreground="Gray"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="{Binding Department}" 
                                                   Foreground="Blue"
                                                   Margin="0,0,15,0"
                                                   Visibility="{Binding HasDepartment, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding Room}" 
                                                   Foreground="Blue"
                                                   Visibility="{Binding HasRoom, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>

                                    <Border Background="{Binding StatusColor}" 
                                            Padding="5,2"
                                            CornerRadius="3"
                                            HorizontalAlignment="Left"
                                            Visibility="{Binding DataContext.CanSeeStatus, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{Binding StatusText}" 
                                                   Foreground="White"
                                                   FontSize="11"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </Grid>
</Window>