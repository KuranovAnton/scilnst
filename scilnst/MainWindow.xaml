<Window x:Class="scilnst.MainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему - Научный институт" 
        Height="400" 
        Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#f0f0f0">

    <Grid>
        <Border Background="White" 
                CornerRadius="10" 
                Padding="20"
                Width="300"
                Height="350"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <StackPanel>
                <Image Source="/Images/logo.png" Width="40"></Image>
                <TextBlock Text="Научный институт" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"
                           Foreground="#2c3e50"/>

                <TextBlock Text="Логин:" 
                           Margin="0,5"/>
                <TextBox x:Name="txtLogin" 
                         Height="30"
                         Padding="5"/>

                <TextBlock Text="Пароль:" 
                           Margin="0,10,0,5"/>
                <PasswordBox x:Name="txtPassword" 
                             Height="30"
                             Padding="5"/>

                <Button Content="Войти" 
                        Click="LoginButton_Click"
                        Background="#3498db"
                        Foreground="White"
                        Height="35"
                        Margin="0,20,0,10"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Войти как гость" 
                        Click="GuestButton_Click"
                        Background="#95a5a6"
                        Foreground="White"
                        Height="35"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
